// This file is auto-generated by Prisma.
// datasource and generator config

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
//  ENUMS
// ─────────────────────────────────────────

enum Role {
  USER
  ORGANIZER
  ADMIN
  HOST
}

enum TripStatus {
  DRAFT
  OPEN
  FULL
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MemberStatus {
  PENDING
  APPROVED
  REJECTED
  LEFT
}

enum ExpenseCategory {
  ACCOMMODATION
  TRANSPORT
  FOOD
  ACTIVITY
  SHOPPING
  OTHER
}

enum NotificationType {
  TRIP_UPDATE
  JOIN_REQUEST
  REQUEST_APPROVED
  REQUEST_REJECTED
  EXPENSE_ADDED
  CHAT_MESSAGE
  PAYMENT_RECEIVED
  SYSTEM
}

// ─────────────────────────────────────────
//  MODELS
// ─────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String
  passwordHash   String?
  googleId       String?   @unique
  avatarUrl      String?
  bio            String?
  role           Role      @default(USER)
  refreshToken   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  organizedTrips   Trip[]         @relation("Organizer")
  memberships      TripMember[]
  messages         Message[]
  expensesPaid     Expense[]      @relation("Payer")
  expenseShares    ExpenseShare[]
  pollVotes        PollVote[]
  notifications    Notification[]
  announcements    Announcement[]
  payments         Payment[]
  vehicles         Vehicle[]
  rentalBookings   RentalBooking[] @relation("Renter")
  rentalListings   RentalListing[]
  rideBookings     RideBooking[]
  verifications    Verification[]
  policyAcceptances PolicyAcceptance[]
  linkedAccounts   LinkedAccount[]

  @@map("users")
}

model Trip {
  id              String      @id @default(uuid())
  title           String
  description     String?
  destination     String
  coverImageUrl   String?
  startDate       DateTime
  endDate         DateTime
  maxParticipants Int         @default(10)
  budgetEstimate  Float?
  status          TripStatus  @default(DRAFT)
  isPublic        Boolean     @default(true)
  organizerId     String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relations
  organizer        User           @relation("Organizer", fields: [organizerId], references: [id], onDelete: Cascade)
  members          TripMember[]
  itineraryItems   ItineraryItem[]
  expenses         Expense[]
  messages         Message[]
  polls            Poll[]
  announcements    Announcement[]
  payments         Payment[]

  @@map("trips")
}

model TripMember {
  id        String       @id @default(uuid())
  tripId    String
  userId    String
  status    MemberStatus @default(PENDING)
  joinedAt  DateTime     @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@map("trip_members")
}

model ItineraryItem {
  id          String   @id @default(uuid())
  tripId      String
  title       String
  description String?
  location    String?
  dayNumber   Int
  startTime   String?
  endTime     String?
  type        String   @default("ACTIVITY")
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("itinerary_items")
}

model Expense {
  id          String          @id @default(uuid())
  tripId      String
  payerId     String
  title       String
  amount      Float
  currency    String          @default("USD")
  category    ExpenseCategory @default(OTHER)
  date        DateTime        @default(now())
  receiptUrl  String?
  createdAt   DateTime        @default(now())

  trip   Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  payer  User           @relation("Payer", fields: [payerId], references: [id])
  shares ExpenseShare[]

  @@map("expenses")
}

model ExpenseShare {
  id         String  @id @default(uuid())
  expenseId  String
  userId     String
  amount     Float
  isPaid     Boolean @default(false)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@map("expense_shares")
}

model Message {
  id        String   @id @default(uuid())
  tripId    String
  userId    String
  content   String
  createdAt DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@map("messages")
}

model Poll {
  id        String     @id @default(uuid())
  tripId    String
  question  String
  options   String[]
  endsAt    DateTime?
  createdAt DateTime   @default(now())

  trip  Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@map("polls")
}

model PollVote {
  id           String @id @default(uuid())
  pollId       String
  userId       String
  selectedOption String

  poll Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([pollId, userId])
  @@map("poll_votes")
}

model Announcement {
  id        String   @id @default(uuid())
  tripId    String
  authorId  String
  title     String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())

  trip   Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@map("announcements")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Payment {
  id              String   @id @default(uuid())
  userId          String
  tripId          String?
  stripePaymentId String   @unique
  amount          Float
  currency        String   @default("USD")
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  trip Trip? @relation(fields: [tripId], references: [id])

  @@map("payments")
}

model Vehicle {
  id              String   @id @default(uuid())
  ownerId         String
  make            String
  model           String
  year            Int
  type            String   @default("CAR")
  licensePlate    String   @unique
  seats           Int
  fuelType        String
  transmission    String
  images          String[]
  rcUrl           String?
  isVerified      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  owner           User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  listings        RentalListing[]

  @@map("vehicles")
}

model RentalListing {
  id              String   @id @default(uuid())
  vehicleId       String
  hostId          String
  pricePerDay     Float
  location        String
  description     String?
  availableFrom   DateTime
  availableTo     DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vehicle         Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  host            User            @relation(fields: [hostId], references: [id], onDelete: Cascade)
  bookings        RentalBooking[]

  @@map("rental_listings")
}

model RentalBooking {
  id              String   @id @default(uuid())
  listingId       String
  renterId        String
  startDate       DateTime
  endDate         DateTime
  totalPrice      Float
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  listing         RentalListing @relation(fields: [listingId], references: [id])
  renter          User          @relation("Renter", fields: [renterId], references: [id])

  @@map("rental_bookings")
}

model RideBooking {
  id              String   @id @default(uuid())
  userId          String
  provider        String
  providerRideId  String?
  pickupLocation  String
  dropoffLocation String
  fare            Float
  currency        String   @default("INR")
  status          String   @default("BOOKED")
  type            String
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])

  @@map("ride_bookings")
}

model Verification {
  id              String   @id @default(uuid())
  userId          String
  documentType    String
  documentNumber  String?
  documentUrl     String?
  digiLockerId    String?
  status          String   @default("PENDING")
  verifiedAt      DateTime?
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("verifications")
}

model PolicyAcceptance {
  id              String   @id @default(uuid())
  userId          String
  policyType      String
  policyVersion   String
  acceptedAt      DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("policy_acceptances")
}

model LinkedAccount {
  id              String   @id @default(uuid())
  userId          String
  provider        String   // UBER, OLA, RAPIDO
  accessToken     String?
  refreshToken    String?
  expiresAt       DateTime?
  isConnected     Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("linked_accounts")
}
